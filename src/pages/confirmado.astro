---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import torchImg from "@img/assets/torch.avif";

const status = Astro.url.searchParams.get("status") ?? "ok";
const reason = Astro.url.searchParams.get("reason") ?? "";

type StatusConfig = {
  icon: string;
  title: string;
  subtitle: string;
};

const configs: Record<string, StatusConfig> = {
  ok: {
    icon: "🔥",
    title: "¡Asistencia confirmada!",
    subtitle: "Te esperamos en la Previa de la LareiraConf'26",
  },
  ya_confirmado: {
    icon: "✓",
    title: "Ya estás apuntado",
    subtitle: "Tu asistencia ya fue registrada anteriormente. ¡Nos vemos en la previa!",
  },
  error: {
    icon: "✕",
    title: "Algo salió mal",
    subtitle:
      reason === "missing_params"
        ? "El enlace de confirmación no contiene los datos necesarios. Revisa el email original."
        : "No se pudo registrar tu confirmación. Si el problema persiste, escríbenos directamente a info@lareiraconf.es",
  },
};

const cfg = configs[status] ?? configs["ok"];
---

<Layout title="Confirmación de asistencia — LareiraConf'26">
  <section class="confirmado-section">
    <div class="confirmado-wrapper">

      <!-- Title plate with torches -->
      <div class="confirmado-title-plate">
        <div class="title-torch title-torch--left">
          <img src={torchImg.src} alt="Antorcha" class="torch-image torch-image--lit" />
        </div>
        <h1 class="confirmado-title">{cfg.title}</h1>
        <div class="title-torch title-torch--right">
          <img src={torchImg.src} alt="Antorcha" class="torch-image torch-image--lit" />
        </div>
      </div>

      <!-- Content card -->
      <div class="confirmado-card">
        <p class="confirmado-subtitle">{cfg.subtitle}</p>

      </div>

    </div>
  </section>
</Layout>

<style>
  .confirmado-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    padding: 2rem 1.5rem;
  }

  .confirmado-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 540px;
    padding-top: 60px; /* espacio para las antorchas que sobresalen */
    animation: fade-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Title plate ── */
  .confirmado-title-plate {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brown);
    border: 3px solid var(--color-brown-dark);
    box-shadow: 0 0 0 3px var(--color-brown-dark), inset 0 0 0 3px var(--color-brown-light);
    padding: 1rem 5rem;
    width: 100%;
  }

  /* ── Card ── */
  .confirmado-card {
    position: relative;
    width: 100%;
    background: var(--color-brown);
    border: 3px solid var(--color-brown-dark);
    box-shadow: 0 0 0 3px var(--color-brown-dark), inset 0 0 0 3px var(--color-brown-light);
    padding: 3rem 2.5rem 2.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .confirmado-title {
    font-family: var(--heading-font), sans-serif;
    font-size: clamp(1rem, 3vw, 1.4rem);
    letter-spacing: var(--custom-letter-spacing);
    text-transform: uppercase;
    color: var(--text-light);
    margin: 0;
  }

  /* ── Torches — centrados verticalmente en la plate, sobresaliendo hacia arriba ── */
  .title-torch {
    position: absolute;
    top: 50%;
    transform: translateY(-60%);
    z-index: 2;
  }

  .title-torch--left  { left: 20px; }
  .title-torch--right { right: 20px; }

  .title-torch::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(255,165,0,0.4) 0%, rgba(255,69,0,0.2) 30%, transparent 70%);
    border-radius: 50%;
    animation: glowFlicker 3s ease-in-out infinite alternate;
    z-index: -1;
  }

  .torch-image {
    width: 70px;
    height: auto;
    image-rendering: pixelated;
    position: relative;
    z-index: 1;
  }

  .torch-image--lit {
    filter: brightness(1.2) saturate(1.5);
    animation: torchFlicker 2s ease-in-out infinite alternate;
  }

  @keyframes torchFlicker {
    0%   { filter: brightness(1.2) saturate(1.5); }
    50%  { filter: brightness(1.4) saturate(1.8) hue-rotate(5deg); }
    100% { filter: brightness(1.1) saturate(1.3) hue-rotate(-2deg); }
  }

  @keyframes glowFlicker {
    0%   { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
    50%  { opacity: 0.8; transform: translate(-50%, -50%) scale(1.05); }
    100% { opacity: 0.4; transform: translate(-50%, -50%) scale(0.95); }
  }

  .confirmado-icon {
    font-size: 2.5rem;
    line-height: 1;
    display: block;
    animation: icon-pop 0.45s 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes icon-pop {
    from { opacity: 0; transform: scale(0.5); }
    to   { opacity: 1; transform: scale(1); }
  }

  .confirmado-subtitle {
    font-family: var(--heading-font), sans-serif;
    font-size: clamp(0.75rem, 2vw, 0.95rem);
    letter-spacing: var(--custom-letter-spacing);
    text-transform: uppercase;
    color: var(--color-text-body-light);
    line-height: 1.7;
    margin: 0;
  }

  .confirmado-link {
    font-family: var(--heading-font), sans-serif;
    font-size: 0.75rem;
    letter-spacing: var(--custom-letter-spacing);
    text-transform: uppercase;
    color: var(--color-text-body-light);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: color 0.15s;
  }

  .confirmado-link:hover {
    color: var(--accent);
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .torch-image { width: 54px; }
    .confirmado-card { padding: 2.5rem 1.5rem 2rem; }
  }
</style>